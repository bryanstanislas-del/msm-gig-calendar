{
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        { "type": "host", "value": "msm-gig-calendar.vercel.app" }
      ],
      "destination": "https://calendar.musicscenemagazine.co.uk/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)",    "destination": "/api/$1" },
    { "source": "/gig/:slug",   "destination": "/api/gig" },
    { "source": "/artist/:slug","destination": "/api/artist" },
    { "source": "/venue/:slug", "destination": "/api/venue" },
    { "source": "/(.*)",        "destination": "/index.html" }
  ]
}
