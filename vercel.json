{
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        { "type": "host", "value": "msm-gig-calendar.vercel.app" }
      ],
      "destination": "https://calendar.musicscenemagazine.co.uk/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)",     "destination": "/api/$1" },
    { "source": "/gig/:slug",    "destination": "/api/gig" },
    { "source": "/artist/:slug", "destination": "/api/og?type=band&slug=:slug" },
    { "source": "/venue/:slug",  "destination": "/api/og?type=venue&slug=:slug" },
    { "source": "/festival/:slug","destination": "/api/og?type=festival&slug=:slug" },
    { "source": "/(.*)",         "destination": "/index.html" }
  ]
}
